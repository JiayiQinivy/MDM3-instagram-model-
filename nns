# =========================
# 0. Load data (from Drive)
# =========================
from google.colab import drive
drive.mount('/content/drive')

import pandas as pd
import numpy as np
import torch
import torch.nn as nn

file_path = "/content/drive/MyDrive/instagram_usage_lifestyle.csv"

features = [
    "daily_active_minutes_instagram",
    "stories_viewed_per_day",
    "likes_given_per_day",
    "time_on_feed_per_day",
    "comments_written_per_day",
    "dms_received_per_week",
    "ads_viewed_per_day",
    "user_engagement_score",
    "reels_watched_per_day",
    "ads_clicked_per_day",
    "posts_created_per_week"
]

target = "perceived_stress_score"

df = pd.read_csv(file_path, usecols=features + [target]).dropna()

# 可选：抽样
df = df.sample(n=100000, random_state=42)

# =========================
# 1. Prepare data
# =========================
X = df[features + [target]].values

from sklearn.preprocessing import StandardScaler

scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

X_tensor = torch.tensor(X_scaled, dtype=torch.float32)

# =========================
# 2. Masked Autoencoder MLP
# =========================
class MaskedMLP(nn.Module):
    def __init__(self, dim):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(dim, 128),
            nn.ReLU(),
            nn.Linear(128, 256),
            nn.ReLU(),
            nn.Linear(256, 128),
            nn.ReLU(),
            nn.Linear(128, dim)
        )

    def forward(self, x):
        return self.net(x)

model = MaskedMLP(dim=X.shape[1])

criterion = nn.MSELoss()
optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)

# =========================
# 3. Training with masking
# =========================
epochs = 20

for epoch in range(epochs):
    model.train()

    # 随机mask（关键🔥）
    mask = (torch.rand_like(X_tensor) > 0.3).float()
    X_masked = X_tensor * mask

    pred = model(X_masked)

    loss = criterion(pred, X_tensor)

    optimizer.zero_grad()
    loss.backward()
    optimizer.step()

    if epoch % 5 == 0:
        print(f"Epoch {epoch}, Loss: {loss.item():.4f}")

# =========================
# 4. Feature control function
# =========================
feature_index = {name: i for i, name in enumerate(features + [target])}

def simulate(control_dict):
    """
    control_dict example:
    {
        "perceived_stress_score": 5,
        "daily_active_minutes_instagram": 200,
        "likes_given_per_day": 150
    }
    """

    # 初始化输入（全部设为0）
    x = np.zeros(len(features) + 1)

    # 填入你控制的变量
    for k, v in control_dict.items():
        idx = feature_index[k]
        x[idx] = v

    # 标准化
    x_scaled = scaler.transform([x])
    x_tensor = torch.tensor(x_scaled, dtype=torch.float32)

    # 预测
    model.eval()
    with torch.no_grad():
        pred = model(x_tensor).numpy()

    pred = scaler.inverse_transform(pred)[0]

    result = dict(zip(features + [target], pred))
    return result

